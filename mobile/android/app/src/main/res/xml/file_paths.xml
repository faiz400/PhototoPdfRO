<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <external-path name="my_images" path="." />
    <cache-path name="my_cache_images" path="." />
    <!-- Directory.Data (Filesystem plugin) maps to Context.getFilesDir(),
         which FileProvider can only serve from if declared here - needed
         so Share.share() can expose the generated PDF (written via
         Directory.Data) to other apps. -->
    <files-path name="my_files" path="." />
</paths>